---
layout: layouts/base.njk
title: Home
description: Sunoco Gas, Convenience Store, Full Kitchen
permalink: /index.html
---
{% from "_components/index.njk" import button, card, badge, accordion %}

{# Hero Section #}
<section class="section bg-gradient-to-b from-primary-50 to-white">
  <div class="container text-center">
    <div class="max-w-4xl mx-auto">
     

      <h1 class="text-balance">
        Visit <span class="text-gradient">One Dream</span> for all of your daily needs.
      </h1>

     

      <div class="flex flex-wrap justify-center gap-4 mt-8">
        {{ button({
          text: "Order Now",
          url: "/menu/",
          variant: "primary",
          size: "lg"
        }) }}


      </div>
    </div>
  </div>
</section>

{# Features Section #}
<section class="section">
  <div class="container">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <h2>Everything you need</h2>
      <p class="mt-4 text-lg text-zinc-600 hc:text-zinc-700">
        Convenience store, Sunoco gas and a full kitchen.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {# Feature 1 #}
      <div class="card">
        <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4 hc:bg-primary-200">
          <span class="text-2xl">🚀</span>
        </div>
        <h3 class="text-xl font-bold mb-2">Sunoco Gas</h3>
        <p class="text-zinc-600 hc:text-zinc-700">
          Open 24 hours a day.
        </p>
      </div>

      {# Feature 2 #}
      <div class="card">
        <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4 hc:bg-primary-200">
          <span class="text-2xl">🎨</span>
        </div>
        <h3 class="text-xl font-bold mb-2">Convenience</h3>
        <p class="text-zinc-600 hc:text-zinc-700">
          Everything you need under one roof.
        </p>
      </div>

      {# Feature 3 #}
      <div class="card">
        <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4 hc:bg-primary-200">
          <span class="text-2xl">⚡</span>
        </div>
        <h3 class="text-xl font-bold mb-2">Full Kitchen</h3>
        <p class="text-zinc-600 hc:text-zinc-700">
          Deli sandwiches, burgers, pizza and more.
        </p>
      </div>


   
    </div>
  </div>
</section>



{# CTA Section #}
<section class="section bg-primary-700 text-white">
  <div class="container text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-white">Ready to get started?</h2>
      <p class="mt-4 text-lg text-primary-100 hc:text-white">
        Clone the repo and start building your next project in minutes.
      </p>
      <div class="flex flex-wrap justify-center gap-4 mt-8">
        {{ button({
          text: "Get Started",
          url: "/contact/",
          variant: "white",
          size: "lg"
        }) }}
      </div>
    </div>
  </div>
</section>
