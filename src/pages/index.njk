{% from "_components/index.njk" import button, card, badge, accordion %}

{# Hero Section #}
<section class="section relative flex min-h-[520px] items-center overflow-hidden bg-cover bg-center md:min-h-[680px]" style="background-image: url('/assets/images/one_dream_cover.jpg');">
  <div class="absolute inset-0 bg-zinc-950/55" aria-hidden="true"></div>
  <div class="container relative text-center">
    <div class="max-w-4xl mx-auto">
     

      <h1 class="text-balance text-white">
        Visit <span class="text-secondary-800">One Dream</span> for everything you need.
      </h1>

     

      <div class="flex flex-wrap justify-center gap-4 mt-8">
        {{ button({
          text: "View Menu",
          url: "/menu/",
          variant: "primary",
          size: "lg"
        }) }}


      </div>
    </div>
  </div>
</section>

{# Features Section #}
<section class="section">
  <div class="container">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <h2 class="text-4xl md:text-7xl">One Stop</h2>
      <p class="mt-4 text-lg text-zinc-600 hc:text-zinc-700">
        Convenience store, Sunoco gas and a full kitchen.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {# Feature 1 #}
      <div class="card">
        <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4 hc:bg-primary-200">
          <span class="text-2xl">🚀</span>
        </div>
        <h3 class="text-xl font-bold mb-2">Sunoco Gas</h3>
        <p class="text-zinc-600 hc:text-zinc-700">
          Open 24 hours a day.
        </p>
      </div>

      {# Feature 2 #}
      <div class="card">
        <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4 hc:bg-primary-200">
          <span class="text-2xl">🎨</span>
        </div>
        <h3 class="text-xl font-bold mb-2">Convenience</h3>
        <p class="text-zinc-600 hc:text-zinc-700">
          Everything you need under one roof.
        </p>
      </div>

      {# Feature 3 #}
      <div class="card">
        <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4 hc:bg-primary-200">
          <span class="text-2xl">⚡</span>
        </div>
        <h3 class="text-xl font-bold mb-2">Full Kitchen</h3>
        <p class="text-zinc-600 hc:text-zinc-700">
          Deli sandwiches, burgers, pizza and more.
        </p>
      </div>


   
    </div>
  </div>
</section>



{# Contact Section #}
<section class="section bg-blue-200 text-zinc-800">
  <div class="container pb-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-12 items-center">
      <div>
        <h2 class="text-zinc-800">Visit One Dream</h2>
        <div class="mt-6 space-y-5 text-lg text-zinc-800 hc:text-white">
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wide text-zinc-800">Address</h3>
            <p class="mt-1">
              9060 State Route 365<br>
              Stittville, NY 13469
            </p>
          </div>

          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wide text-zinc-800">Phone</h3>
            <p class="mt-1">
              <a class="text-zinc-800 hover:text-white hc:text-white hc:underline" href="tel:+13158658044">
                315 865-8044
              </a>
            </p>
          </div>
        </div>
      </div>

      <div class="overflow-hidden rounded-lg border border-primary-500 bg-white">
        <iframe
          class="h-80 w-full md:h-96"
          title="Map to One Dream"
          src="https://www.google.com/maps?q=9060%20State%20Route%20365%2C%20Stittville%2C%20NY%2013469&z=13&output=embed"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </div>
</section>
